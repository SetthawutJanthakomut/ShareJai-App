const getCycleRange = (dateInput) => {
        const date = new Date(dateInput);
        const day = date.getDate();
        const month = date.getMonth();
        const year = date.getFullYear();
        let startDate, endDate, cycleName;

        // เปลี่ยนเงื่อนไขจาก 5 เป็น 20
        if (day >= 20) {
          startDate = new Date(year, month, 20); // เริ่มวันที่ 20
          endDate = new Date(year, month + 1, 19, 23, 59, 59); // จบวันที่ 19 ของเดือนถัดไป
          const nextMonthDate = new Date(year, month + 1, 1);
          // แก้ไขชื่อรอบ
          cycleName = `รอบ 20 ${date.toLocaleString('th-TH', { month: 'short' })} - 19 ${nextMonthDate.toLocaleString('th-TH', { month: 'short' })}`;
        } else {
          startDate = new Date(year, month - 1, 20); // เริ่มวันที่ 20 เดือนก่อน
          endDate = new Date(year, month, 19, 23, 59, 59); // จบวันที่ 19 เดือนปัจจุบัน
          const prevMonthDate = new Date(year, month - 1, 1);
          // แก้ไขชื่อรอบ
          cycleName = `รอบ 20 ${prevMonthDate.toLocaleString('th-TH', { month: 'short' })} - 19 ${date.toLocaleString('th-TH', { month: 'short' })}`;
        }
        return { startDate, endDate, cycleName };
      };

      const currentCycleInfo = useMemo(() => getCycleRange(viewDate), [viewDate]);

